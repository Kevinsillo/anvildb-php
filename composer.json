{
    "name": "kevinsillo/anvildb",
    "description": "AnvilDB — High-performance JSON file-based storage engine with Rust core and PHP FFI wrapper",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "AnvilDb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AnvilDb\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    }
}
